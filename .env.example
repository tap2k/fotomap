# Frontend URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Strapi backend URL
NEXT_PUBLIC_STRAPI_HOST=http://127.0.0.1:1337

# Secret for XOR encryption of channel IDs (privateID <-> uniqueID)
# Must match the value in the Strapi backend .env
PRIVATE_SEED=<random-64-char-hex-string>

# Optional. Admin URL for supabase-provider users (UX4ME login button).
# Leave unset to disable the button.
# NEXT_PUBLIC_UX4ME_URL=

# Shared secret sent to the Strapi backend's /updateUserPlan endpoint from the
# Stripe webhook. Must match WEBHOOK_SECRET in the Strapi backend .env.
WEBHOOK_SECRET=<random-string>
